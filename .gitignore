node_modules
.tmp
.tmp-screens
*.log
.DS_Store
.env
.env.local
dist
*.tsbuildinfo
coverage
.idea/workspace.xml

# Local dev secrets — keys/PEMs must never be checked in. Generate per-machine
# with `openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048`.
*.pem
*.key

# Workspace-managed lockfile lives at the root; nested ones are an error.
my-app/package-lock.json
apps/*/package-lock.json
packages/*/package-lock.json

# Agent skills: vendored real copies live in .claude/skills/ (committed so
# teammates auto-discover them on clone). .agents/ is the CLI's canonical
# source cache (the "node_modules" of `npx skills`) — regenerable, not committed.
.agents/
