# React Native 0.85 / React 19.2 / Expo SDK 56 is ahead of several native
# libraries' declared peer ranges (e.g. @config-plugins/react-native-webrtc
# pins `expo ^55` with no SDK-56 release published yet, and various RN libs
# pin `react`/`react-native` ranges below 0.85). These mismatches are advisory
# — the libraries work on this stack. Accept them so installs resolve instead
# of hard-failing ERESOLVE.
legacy-peer-deps=true
