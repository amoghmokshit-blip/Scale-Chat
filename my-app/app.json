{
  "expo": {
    "name": "my-app",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.surya_expo88.myapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ScaleChat needs microphone access for voice and video calls.",
        "NSCameraUsageDescription": "ScaleChat needs camera access for video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.surya_expo88.myapp",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "ScaleChat needs microphone access to record voice notes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ScaleChat needs photo library access so you can share images in chats.",
          "cameraPermission": "ScaleChat needs camera access so you can take photos to share in chats."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "ScaleChat looks at your contacts to find friends who already use the app. We never upload your full address book — only matches are shown, and nothing is saved until you tap Save."
        }
      ],
      "expo-video",
      "expo-build-properties",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ScaleChat needs your location to share where you are in a chat."
        }
      ],
      "@config-plugins/react-native-webrtc",
      "@livekit/react-native-expo-plugin",
      [
        "expo-notifications",
        {
          "color": "#208AEF"
        }
      ],
      "./plugins/with-android-gradle-heap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cecf2c91-ebb2-4f31-a2fb-43d97b0920b7"
      }
    },
    "owner": "mokshith-03"
  }
}
