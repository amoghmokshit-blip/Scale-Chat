// ScaleChat database schema.
//
// Scope today (per current product slice):
//   - User (account-setup output)
//   - RefreshToken with family-based rotation for replay detection
//   - OtpRequest is a *log* table — the live OTP itself lives in Redis (5-min TTL)
//   - SecurityEvent for audit / on-call paging hooks
//
// Future tables (chat, super-groups, payments) live behind their own migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid()) @db.Uuid
  phoneE164   String   @unique @db.VarChar(16)
  fullName    String   @db.VarChar(60)
  bio         String?  @db.VarChar(160)
  avatarUri   String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  refreshTokens   RefreshToken[]
  otpRequests     OtpRequest[]
  securityEvents  SecurityEvent[]
  ownedContacts   Contact[]      @relation("ContactOwner")
  contactedBy     Contact[]      @relation("ContactTarget")
  chatMemberships ChatMember[]
  sentMessages    Message[]      @relation("MessageSender")
  createdChats    Chat[]         @relation("ChatCreator")
  chatFilters     UserChatFilter[]
  reportsFiled    MessageReport[] @relation("ReporterUser")
  blocksMade      BlockedUser[]  @relation("BlockerUser")
  blockedBy       BlockedUser[]  @relation("BlockedTargetUser")
  starredMessages StarredMessage[] @relation("UserStarredMessages")
  messageReactions MessageReaction[] @relation("UserReactions")
  pinnedMessages  Message[]      @relation("MessagePinnedBy")
  pollVotes       PollVote[]     @relation("UserPollVotes")
  callsInitiated  CallSession[]  @relation("CallInitiator")
  callsReceived   CallSession[]  @relation("CallCallee")
  devices         UserDevice[]   @relation("UserDevices")

  @@index([phoneE164])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Refresh tokens (family-based rotation)
//
// `familyId` is set on first verify; every rotation reuses the same familyId
// while issuing a new token (`tokenHash`). When a refresh fails because the
// presented token is already rotated, we revoke the WHOLE family (replay detection)
// and emit a SecurityEvent.
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  familyId     String   @db.Uuid
  tokenHash    String   // argon2 hash of the opaque random token (raw token never stored)
  deviceId     String   @db.VarChar(128)
  // Set on rotate: this row points to its successor so replay detection can walk the chain.
  rotatedToId  String?  @unique @db.Uuid
  rotatedAt    DateTime? @db.Timestamptz(6)
  revokedAt    DateTime? @db.Timestamptz(6)
  expiresAt    DateTime @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  userAgent    String?  @db.VarChar(256)
  ipAddress    String?  @db.VarChar(64)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// OTP request log
//
// The hashed OTP itself lives in Redis with a 5-minute TTL (cheap and TTLs itself
// out). This table is a durable audit log — every request lands here so we can
// reconstruct rate-limit reasoning even after Redis evicts the keys.
// ─────────────────────────────────────────────────────────────────────────────

model OtpRequest {
  id          String   @id @default(uuid()) @db.Uuid
  phoneE164   String   @db.VarChar(16)
  // Nullable: phone may not yet correspond to a user on first request.
  userId      String?  @db.Uuid
  requestId   String   @unique @db.Uuid
  status      OtpStatus @default(SENT)
  provider    String   @default("msg91") @db.VarChar(32)
  providerRef String?  @db.VarChar(128)  // MSG91 request id (for support / log correlation)
  ipAddress   String?  @db.VarChar(64)
  userAgent   String?  @db.VarChar(256)
  attempts    Int      @default(0)
  expiresAt   DateTime @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  verifiedAt  DateTime? @db.Timestamptz(6)

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneE164, createdAt])
  @@index([ipAddress, createdAt])
  @@map("otp_requests")
}

enum OtpStatus {
  SENT
  VERIFIED
  EXPIRED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Security events
//
// Append-only audit of anything an on-call would want to know about. The
// PrivacyInterceptor and refresh-replay path both emit here. Long-term these
// feed the anomaly detector mentioned in CLAUDE.md §4 "Layer 3".
// ─────────────────────────────────────────────────────────────────────────────

model SecurityEvent {
  id         String   @id @default(uuid()) @db.Uuid
  kind       SecurityEventKind
  userId     String?  @db.Uuid
  phoneE164  String?  @db.VarChar(16)
  ipAddress  String?  @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([kind, createdAt])
  @@index([userId])
  @@map("security_events")
}

enum SecurityEventKind {
  REFRESH_REPLAY_DETECTED
  REFRESH_FAMILY_REVOKED
  OTP_RATE_LIMIT_HIT
  OTP_MAX_ATTEMPTS_HIT
  SIGNOUT
  PROFILE_UPDATED
  PII_LEAK_DETECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// Contacts directory
//
// One row per (owner, target) pair. `contactUserId` is nullable so an owner
// can save a phone that hasn't joined the platform yet — when the target
// signs up, a separate worker job back-fills the userId.
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id              String   @id @default(uuid()) @db.Uuid
  ownerUserId     String   @db.Uuid
  contactUserId   String?  @db.Uuid
  phoneE164       String   @db.VarChar(16)
  displayName     String   @db.VarChar(60)
  favouriteAt     DateTime? @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  owner           User     @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  contactUser     User?    @relation("ContactTarget", fields: [contactUserId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, phoneE164])
  @@index([ownerUserId, favouriteAt])
  @@index([contactUserId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Chats / Messages
//
// `Chat` is the conversation envelope; `ChatMember` is the per-user view onto
// it (read sequence, mute, favourite, archive). 1-on-1 uniqueness is enforced
// in the `chats` service by deterministic member-pair hashing — Prisma alone
// can't express a constraint over a join table.
// ─────────────────────────────────────────────────────────────────────────────

model Chat {
  id                String     @id @default(uuid()) @db.Uuid
  kind              ChatKind
  /// Group / super-group title. Null for 1-on-1 (counterpart name is rendered
  /// client-side from the other ChatMember's User row).
  title             String?    @db.VarChar(80)
  /// Audience description for Super Groups (shown to admin only).
  description       String?    @db.VarChar(280)
  avatarUri         String?
  createdByUserId   String     @db.Uuid
  lastMessageId     String?    @db.Uuid
  lastMessageAt     DateTime?  @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)

  createdBy         User       @relation("ChatCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  members           ChatMember[]
  messages          Message[]  @relation("ChatMessages")
  lastMessage       Message?   @relation("ChatLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  callSessions      CallSession[] @relation("ChatCalls")

  @@index([kind, lastMessageAt])
  @@index([lastMessageAt])
  @@map("chats")
}

enum ChatKind {
  ONE_ON_ONE
  GROUP
  SUPER_GROUP
}

model ChatMember {
  id                   String     @id @default(uuid()) @db.Uuid
  chatId               String     @db.Uuid
  userId               String     @db.Uuid
  role                 MemberRole @default(MEMBER)
  joinedAt             DateTime   @default(now()) @db.Timestamptz(6)
  leftAt               DateTime?  @db.Timestamptz(6)
  mutedUntil           DateTime?  @db.Timestamptz(6)
  pinnedAt             DateTime?  @db.Timestamptz(6)
  archivedAt           DateTime?  @db.Timestamptz(6)
  favouriteAt          DateTime?  @db.Timestamptz(6)
  /// Per-user "Clear chat" cutoff. Messages with createdAt <= clearedAt are
  /// hidden from THIS user's list view while remaining visible to peers.
  /// Counterpart's history is unaffected — matches WhatsApp behavior.
  clearedAt            DateTime?  @db.Timestamptz(6)
  /// BigInt sequence the member has read up to, drives unread counts.
  lastReadSequence     BigInt     @default(0)

  chat                 Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, archivedAt])
  @@index([userId, favouriteAt])
  @@map("chat_members")
}

enum MemberRole {
  ADMIN
  MEMBER
}

model Message {
  id                String       @id @default(uuid()) @db.Uuid
  chatId            String       @db.Uuid
  senderUserId      String       @db.Uuid
  /// Idempotency: a second send from the same sender with the same clientId returns the existing row.
  clientMessageId   String       @db.VarChar(64)
  /// Per-chat monotonically increasing sequence. Allocated under advisory lock.
  sequence          BigInt
  kind              MessageKind
  text              String?      @db.VarChar(4000)
  mediaObjectKey    String?      @db.VarChar(256)
  /// IMAGE only: intrinsic pixel width — drives bubble aspect-ratio pre-load.
  imageWidth        Int?
  /// IMAGE only: intrinsic pixel height.
  imageHeight       Int?
  durationSec       Int?
  waveform          Json?
  /// DOCUMENT/VIDEO: exact MIME so the bubble picks the right icon + the client passes it back on download.
  mediaMimeType     String?      @db.VarChar(80)
  /// VIDEO only.
  videoDurationSec  Int?
  videoWidth        Int?
  videoHeight       Int?
  /// LOCATION / LOCATION_LIVE.
  latitude          Float?       @db.DoublePrecision
  longitude         Float?       @db.DoublePrecision
  locationName      String?      @db.VarChar(120)
  liveLocationExpiresAt DateTime? @db.Timestamptz(6)
  /// CONTACT_CARD.
  contactName       String?      @db.VarChar(120)
  contactPhoneE164  String?      @db.VarChar(20)
  /// DOCUMENT.
  documentTitle     String?      @db.VarChar(255)
  documentSizeBytes BigInt?
  /// Forward (Tranche 2.E builds the endpoint; column lands here as the schema foundation).
  forwardedFromMessageId String? @db.Uuid
  forwardCount      Int          @default(0)
  /// Pin (Tranche 2.E builds the endpoint; columns land here as the schema foundation).
  pinnedAt          DateTime?    @db.Timestamptz(6)
  pinnedByUserId    String?      @db.Uuid
  replyToMessageId  String?      @db.Uuid
  createdAt         DateTime     @default(now()) @db.Timestamptz(6)
  deletedAt         DateTime?    @db.Timestamptz(6)

  chat              Chat         @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)
  sender            User         @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Restrict)
  replyTo           Message?     @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies           Message[]    @relation("MessageReply")
  forwardedFrom     Message?     @relation("MessageForwards", fields: [forwardedFromMessageId], references: [id], onDelete: SetNull)
  forwardedCopies   Message[]    @relation("MessageForwards")
  pinnedBy          User?        @relation("MessagePinnedBy", fields: [pinnedByUserId], references: [id], onDelete: SetNull)
  chatLastForChat   Chat[]       @relation("ChatLastMessage")
  reports           MessageReport[] @relation("ReportedMessage")
  stars             StarredMessage[] @relation("MessageStars")
  reactions         MessageReaction[] @relation("MessageReactions")
  /// Populated on POLL kinds (Tranche 2.F). 1:1 — the `message_id` column on
  /// `poll_messages` is UNIQUE.
  pollMessage       PollMessage?     @relation("MessagePoll")
  /// Back-ref from a CALL_EVENT message to its CallSession (Tranche 2.H). 1:1.
  callSession       CallSession?     @relation("CallEventMessage")

  @@unique([senderUserId, clientMessageId])
  @@unique([chatId, sequence])
  @@index([chatId, createdAt])
  @@index([forwardedFromMessageId])
  @@index([chatId, pinnedAt])
  @@map("messages")
}

enum MessageKind {
  TEXT
  VOICE
  IMAGE
  SYSTEM
  DOCUMENT
  VIDEO
  LOCATION
  LOCATION_LIVE
  CONTACT_CARD
  POLL
  CALL_EVENT
}

// ─────────────────────────────────────────────────────────────────────────────
// User-defined custom chat filter ("Add" chip in the Contact Page Filter menu).
//
// `criteria` is a JSON blob validated server-side against the zod schema
// `ChatFilterCriteriaSchema` (packages/shared/src/schemas/chat-filters.ts).
// Server folds it into the chat list `where` so pagination cursors stay valid;
// client only sends `customFilterId=<uuid>` on the read path.
// ─────────────────────────────────────────────────────────────────────────────

model UserChatFilter {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  /// User-given name shown as the chip label. ≤60 chars (matches contacts.displayName cap).
  name      String   @db.VarChar(60)
  /// { kinds?: ChatKind[], unread?: boolean, favourite?: boolean, archived?: boolean, mutedExcluded?: boolean }
  criteria  Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_chat_filters")
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-message moderation report.
//
// A reporter (the reader of a counterpart's bubble) submits a reason; the row
// lives server-side only and is never broadcast. A user can re-report the
// same message with a different reason but cannot duplicate the same (reason)
// — the unique constraint stops repeated taps from spamming the queue.
//
// Privacy: this table is the only place where one user's id is paired with
// another's *message body* outside the normal chat stream. The privacy
// interceptor must keep it out of any non-admin DTO surface (admins-only
// console / moderation tooling).
// ─────────────────────────────────────────────────────────────────────────────

model MessageReport {
  id              String          @id @default(uuid()) @db.Uuid
  messageId       String          @db.Uuid
  reporterUserId  String          @db.Uuid
  reason          ReportReason
  /// Optional free-form note (≤500 chars) — useful for the "Other" reason.
  note            String?         @db.VarChar(500)
  status          ReportStatus    @default(OPEN)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  resolvedAt      DateTime?       @db.Timestamptz(6)

  message         Message         @relation("ReportedMessage", fields: [messageId], references: [id], onDelete: Cascade)
  reporter        User            @relation("ReporterUser", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@unique([messageId, reporterUserId, reason])
  @@index([status, createdAt])
  @@map("message_reports")
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-user block list.
//
// One row per (blocker → blocked) direction. Blocking is one-way at the
// database level but enforced symmetrically at the message layer — if either
// party has blocked the other, sends and broadcasts between them are dropped.
//
// Privacy: a blocked sender's existing messages remain in the recipient's
// history (matches WhatsApp); new sends fail at the server and the gateway
// doesn't broadcast `message:new` to the blocker. Chat list rows continue to
// appear with a "Blocked" label so the user can unblock from the same surface.
// ─────────────────────────────────────────────────────────────────────────────

model BlockedUser {
  blockerUserId String   @db.Uuid
  blockedUserId String   @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  blocker       User     @relation("BlockerUser", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User     @relation("BlockedTargetUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([blockerUserId, blockedUserId])
  @@index([blockedUserId])
  @@map("blocked_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Starred messages (Phase D.3) — per-user bookmark on a single message.
//
// `(userId, messageId)` is unique (a user starring the same message twice is
// idempotent). `chatId` is denormalised so the `GET /me/starred` listing can
// page by `(userId, starredAt DESC)` without joining the message row twice.
//
// Tombstoned messages (deletedAt != null) stay in the star list with their
// content zeroed — clients render the standard "This message was deleted"
// placeholder. Server doesn't auto-unstar on delete so the bookmark survives
// even if the sender retracts; this matches WhatsApp's behaviour.
// ─────────────────────────────────────────────────────────────────────────────

model StarredMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  messageId String   @db.Uuid
  chatId    String   @db.Uuid
  starredAt DateTime @default(now()) @db.Timestamptz(6)

  user      User     @relation("UserStarredMessages", fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation("MessageStars", fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, starredAt])
  @@index([chatId])
  @@map("starred_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Message reactions (Phase 2.1) — emoji reactions on a message.
//
// A user can react to a message with multiple distinct emojis but not the
// same emoji twice — `(messageId, userId, emoji)` is unique. Server-side we
// aggregate per emoji on read: `{ emoji, count, reactedByMe }[]`.
//
// `emoji` is stored as a short utf8 string (≤ 16 bytes covers multi-codepoint
// emojis with skin tones / ZWJ sequences). The Prisma layer doesn't enforce
// the emoji-ness — that validation lives in the zod schema in
// `packages/shared`.
// ─────────────────────────────────────────────────────────────────────────────

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  message   Message  @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Polls (Tranche 2.F — 1-on-1 scope).
//
// Three tables back the POLL message kind. `PollMessage` is 1:1 with the
// underlying `Message` row (server-authored via `MessagesService.createServerAuthored`);
// options hang off it; each vote is one row in `PollVote` keyed by
// `(pollMessageId, voterUserId, pollOptionId)` for natural-key idempotency
// (Prisma P2002 on retry is swallowed by the service).
//
// Concurrency: the polls service serialises concurrent votes on the same poll
// under `pg_advisory_xact_lock(hash(poll_message_id))`. Different polls don't
// contend, even within the same chat.
//
// The schema is intentionally general (single/multi-select, anonymous flag,
// closed_at) so a future Super Groups BRD can reuse it without a migration.
// 1-on-1 UI hides the anonymous toggle (zero value with 2 voters).
// ─────────────────────────────────────────────────────────────────────────────

model PollMessage {
  id          String   @id @default(uuid()) @db.Uuid
  messageId   String   @unique @db.Uuid @map("message_id")
  question    String   @db.VarChar(300)
  anonymous   Boolean  @default(false)
  multiSelect Boolean  @default(false) @map("multi_select")
  closedAt    DateTime? @db.Timestamptz(6) @map("closed_at")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  message     Message      @relation("MessagePoll", fields: [messageId], references: [id], onDelete: Cascade)
  options     PollOption[] @relation("PollMessageOptions")
  votes       PollVote[]   @relation("PollMessageVotes")

  @@map("poll_messages")
}

model PollOption {
  id            String @id @default(uuid()) @db.Uuid
  pollMessageId String @db.Uuid @map("poll_message_id")
  ordinal       Int
  label         String @db.VarChar(120)

  pollMessage   PollMessage @relation("PollMessageOptions", fields: [pollMessageId], references: [id], onDelete: Cascade)
  votes         PollVote[]  @relation("PollOptionVotes")

  @@unique([pollMessageId, ordinal])
  @@map("poll_options")
}

model PollVote {
  id            String   @id @default(uuid()) @db.Uuid
  pollMessageId String   @db.Uuid @map("poll_message_id")
  pollOptionId  String   @db.Uuid @map("poll_option_id")
  voterUserId   String   @db.Uuid @map("voter_user_id")
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  pollMessage   PollMessage @relation("PollMessageVotes", fields: [pollMessageId], references: [id], onDelete: Cascade)
  pollOption    PollOption  @relation("PollOptionVotes", fields: [pollOptionId], references: [id], onDelete: Cascade)
  voter         User        @relation("UserPollVotes", fields: [voterUserId], references: [id], onDelete: Cascade)

  @@unique([pollMessageId, voterUserId, pollOptionId])
  @@index([pollOptionId], map: "poll_votes_by_option_idx")
  @@index([pollMessageId, voterUserId], map: "poll_votes_by_voter_idx")
  @@map("poll_votes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Calls (Tranche 2.H — 1-on-1 scope).
//
// One row per call lifecycle. Status transitions:
//   RINGING → ACCEPTED → COMPLETED                  (happy path)
//   RINGING → DECLINED                              (callee declines)
//   RINGING → MISSED                                (BullMQ ring-timeout fires)
//
// `callEventMessageId` back-references the in-thread CALL_EVENT row that
// the calls service inserts on every terminal transition. Nullable because
// RINGING has no chat message yet (the CALL_EVENT only lands on
// MISSED/DECLINED/COMPLETED).
//
// Provider-agnostic: `hmsRoomId` is the provider-side room ID (100ms or
// LiveKit Cloud — see docs/architecture/calls-provider-poc.md). Provider
// swap is contained in apps/api/src/modules/calls/hms.client.ts.
// ─────────────────────────────────────────────────────────────────────────────

model CallSession {
  id                   String     @id @default(uuid()) @db.Uuid
  chatId               String     @db.Uuid @map("chat_id")
  initiatorUserId      String     @db.Uuid @map("initiator_user_id")
  calleeUserId         String     @db.Uuid @map("callee_user_id")
  kind                 CallKind
  status               CallStatus
  hmsRoomId            String?    @db.VarChar(64) @map("hms_room_id")
  startedAt            DateTime?  @db.Timestamptz(6) @map("started_at")
  endedAt              DateTime?  @db.Timestamptz(6) @map("ended_at")
  durationSec          Int?       @map("duration_sec")
  callEventMessageId   String?    @unique @db.Uuid @map("call_event_message_id")
  createdAt            DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")

  chat                 Chat       @relation("ChatCalls", fields: [chatId], references: [id], onDelete: Cascade)
  initiator            User       @relation("CallInitiator", fields: [initiatorUserId], references: [id], onDelete: Restrict)
  callee               User       @relation("CallCallee", fields: [calleeUserId], references: [id], onDelete: Restrict)
  callEventMessage     Message?   @relation("CallEventMessage", fields: [callEventMessageId], references: [id], onDelete: SetNull)

  @@index([chatId, createdAt(sort: Desc)], map: "call_sessions_by_chat_idx")
  @@index([initiatorUserId, createdAt(sort: Desc)], map: "call_sessions_by_initiator_idx")
  @@index([calleeUserId, createdAt(sort: Desc)], map: "call_sessions_by_callee_idx")
  @@map("call_sessions")
}

enum CallKind {
  VOICE
  VIDEO

  @@map("call_kind")
}

enum CallStatus {
  RINGING
  ACCEPTED
  DECLINED
  MISSED
  COMPLETED

  @@map("call_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// Push device registry (Tranche 2.I — call wakeup via Expo push)
//
// One row per (device) Expo push token. The token is the natural key —
// reinstalling/reissuing rotates it, so we upsert on it and reassign userId.
// Platform-agnostic: Expo's push service fans out to FCM (Android) + APNs (iOS).

model UserDevice {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid @map("user_id")
  expoPushToken String         @unique @db.VarChar(200) @map("expo_push_token")
  platform      DevicePlatform
  lastActiveAt  DateTime       @default(now()) @db.Timestamptz(6) @map("last_active_at")
  createdAt     DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")

  user          User           @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_devices_by_user_idx")
  @@map("user_devices")
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}
