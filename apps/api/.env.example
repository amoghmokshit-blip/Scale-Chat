# ---------- Runtime ----------
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ---------- Database (Neon) ----------
# Format: postgresql://user:pass@host/db?sslmode=require&pgbouncer=true
DATABASE_URL=postgresql://localhost:5432/scalechat

# ---------- Redis (Upstash) ----------
# rediss://default:password@region-redis.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ---------- JWT ----------
# RS256 — generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#                        openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode each: base64 -i private.pem | tr -d '\n'
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ISSUER=scalechat
JWT_AUDIENCE=scalechat-mobile
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# ---------- MSG91 (legacy India-only path) ----------
# Provider account for OTP SMS. Leave blank in dev to fall back to console-log delivery.
# In Phase 2 this is the fallback when no Twilio creds are configured.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SCLCHT
MSG91_TEMPLATE_ID=
MSG91_BASE_URL=https://control.msg91.com

# ---------- Twilio Verify (worldwide OTP — preferred) ----------
# When all three are set, the API binds TwilioVerifyProvider. Otherwise it falls
# back to the dev/MSG91 path. Required for NODE_ENV=production unless MSG91 is set.
# Create the Verify Service in the Twilio console; enable Fraud Guard + Geo-Permissions.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---------- Rate limits ----------
OTP_REQUEST_PER_PHONE_PER_HOUR=5
OTP_REQUEST_PER_IP_PER_HOUR=20
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_TTL_SECONDS=300

# ---------- Country allow-list (SMS-pumping / AIT defense) ----------
# Comma-separated ISO 3166-1 alpha-2 codes (e.g. IN,US,GB). Empty = allow all
# (dev default). In prod set to the markets you've cleared registration for
# (US 10DLC, India DLT, etc.) — phones outside the list are rejected before
# any provider call so SMS-pumping attacks can't drain spend.
OTP_ALLOWED_COUNTRIES=

# ---------- Dev knobs ----------
# Set to "true" to short-circuit OTP verify with a fixed dev code (see auth.controller). Off in prod.
ENABLE_DEV_OTP=false
DEV_OTP_CODE=1234

# ---------- CORS ----------
# Comma-separated list of allowed origins. Mobile app uses scheme `myapp://` so HTTP CORS is mainly for web/dev.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
